# ============================================================================
# cyp-agent 配置参考。复制为 .env 后按需取消注释并填写。
# 默认值 = 零密钥、模拟盘、mock LLM，可端到端跑通。
# ============================================================================

# ---- 运行模式 ----------------------------------------------------------------
CYP_MODE=paper
# dashboard（默认，Web/API 审批）/ auto（白名单自动审批）；cli 为废弃别名=dashboard
CYP_APPROVAL=dashboard
# 自动化总开关默认关闭；可在 Dashboard 顶部或设置页运行时切换并持久化。
# 原生止损止盈不受此开关影响。旧 CYP_APPROVAL=auto 会在首次加载时兼容迁移。
# CYP_AUTOMATION_ENABLED=false
# CYP_AUTO_SCAN=true
# CYP_AUTO_APPROVE=true
# CYP_AUTO_EXIT=true
# 自动审批：白名单、风险、金额、置信度、RR、正期望和正 Kelly 必须全部满足。
# CYP_AUTO_SYMBOLS=BTC/USDT,ETH/USDT
# CYP_AUTO_MAX_RISK_SCORE=0.5
# CYP_AUTO_MAX_QUOTE=200
# CYP_AUTO_MIN_CONFIDENCE=0.65
# CYP_AUTO_MIN_REWARD_RISK=1.5
# 主动退出：EWMA 波动率动态跟踪 + 时间止损，所有距离按初始风险 R 归一化。
# CYP_EXIT_EWMA_LAMBDA=0.94
# CYP_EXIT_VOLATILITY_MULTIPLIER=3
# CYP_EXIT_TRAIL_ACTIVATION_R=1
# CYP_EXIT_TRAIL_GIVEBACK_R=0.5
# CYP_EXIT_MAX_HOLDING_MINUTES=360
# CYP_EXIT_TIME_STOP_MIN_R=0
# CYP_EXIT_CONFIRMATIONS=2
# CYP_EXIT_MIN_SAMPLES=8
CYP_KILL=0
CYP_ALLOW_PERP=0
CYP_EXECUTION_VENUE=paper
CYP_DATA_SOURCE=synthetic

# ---- LLM（缺失则所有 Agent 降级为规则模板）----------------------------------
# CYP_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
CYP_LLM_MODEL=claude-opus-4-8
CYP_LLM_MODEL_FAST=claude-haiku-4-5-20251001

# DeepSeek（OpenAI-compatible；启用时取消注释以下配置）
# CYP_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# 启动期配置；运行中的 HTTP 设置接口不能修改该地址。
# CYP_LLM_BASE_URL=https://api.deepseek.com
# CYP_LLM_MODEL=deepseek-chat
# CYP_LLM_MODEL_FAST=deepseek-chat

# ---- LLM 成本护栏（四重硬上限，任一触发即优雅终止）--------------------------
CYP_MAX_ITERATIONS=20
CYP_MAX_TOKENS=200000
CYP_MAX_COST_USD=2.0
CYP_MAX_WALL_SECONDS=300

# ---- CEX（真实下单硬禁用；可选 OKX Demo USDT 永续执行）--------------------
CYP_CEX_ID=binance
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
CYP_LIVE_ACK=0
# Binance 和真实 OKX 即使提供凭据也不会发出订单。

# ---- OKX Demo 账户执行（可选，仅 USDT 线性永续）-----------------------------
# 需从 OKX Demo Trading 单独创建 API key，不可使用生产 key。
# 同时设置：CYP_MODE=paper、CYP_EXECUTION_VENUE=okx、CYP_DATA_SOURCE=cex、
# CYP_CEX_ID=okx、CYP_ALLOW_PERP=1；标的格式示例 BTC/USDT:USDT。
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSWORD=
CYP_OKX_DEMO=true
# Demo key 只开读取+交易权限，禁止提现，并配置 IP 白名单。

# ---- 告警（可选）------------------------------------------------------------
# CYP_ALERT_WEBHOOK=

# ---- 链上（M3；留空则 OnchainVenue 不可用，不影响 CEX）----------------------
# CYP_EVM_RPC_URL=
CYP_SIGNER=keystore
# CYP_KEYSTORE_PATH=

# ---- 外部数据源 --------------------------------------------------------------
# 链上指标只读 API：GET {URL}?symbol=... 返回 contracts.OnchainData JSON。
# 留空则链上分析师使用行情源自带数据（合成源内置，CEX 源降级）。
# CYP_ONCHAIN_DATA_API=
# 情绪数据源尚未实现：当前版本不读取，情绪分析师使用内置降级数据。
# CYP_SENTIMENT_API=

# ---- 风控硬护栏（实盘应显式设置且比默认更保守，详见 docs/RISK.md）-----------
CYP_MAX_RISK_PER_TRADE=0.01
CYP_MAX_POSITION_PCT=0.20
CYP_MAX_GROSS_EXPOSURE=1.00
CYP_MAX_SYMBOL_CONCENTRATION=0.30
CYP_MAX_CORRELATED_EXPOSURE=0.50
CYP_MAX_CVAR_PCT=0.03
CYP_MAX_LEVERAGE=3
CYP_MIN_LIQ_BUFFER=0.30
CYP_FORCE_ISOLATED=true
CYP_MIN_MARGIN_RATIO=0.05
CYP_MAX_SLIPPAGE_BPS=30
# 链上专项（§2.3）
CYP_MAX_PRICE_IMPACT=0.01
# CYP_MAX_GAS_GWEI=
CYP_MAX_GAS_QUOTE=20
CYP_MIN_POOL_TVL=1000000
# 合约/路由白名单（逗号分隔小写地址；空 = 链上全拒）
# CYP_CONTRACT_WHITELIST=
CYP_REQUIRE_PRIVATE_MEMPOOL=true
CYP_DAILY_DRAWDOWN_LIMIT=0.03
CYP_WEEKLY_DRAWDOWN_LIMIT=0.08
CYP_MAX_DRAWDOWN_LIMIT=0.15
CYP_MAX_CONSECUTIVE_LOSSES=4
CYP_MAX_ORDERS_PER_HOUR=10
CYP_APPROVAL_TIMEOUT_SECONDS=1800

# ---- 运行时（扫描 + 监控双循环）----------------------------------------------
# true：Go 服务启动时同时启动 RuntimeEngine（扫描+监控）
CYP_RUNTIME_AUTOSTART=false
CYP_SCAN_INTERVAL=300
CYP_MONITOR_INTERVAL=15
CYP_WATCHLIST=BTC/USDT
CYP_MAX_CONCURRENCY=2

# ---- 持久化 & 可观测 --------------------------------------------------------
# 监听 127.0.0.1 之外的地址（包括 Docker 容器内 0.0.0.0）时必填。
# 请使用高强度随机值；Dashboard 只把它保存在浏览器 localStorage 中。
# CYP_API_TOKEN=
# memory / file / postgres；默认原子 JSON 文件，无数据库也可恢复检查点与经验。
CYP_PERSISTENCE=file
CYP_STATE_FILE=data/cyp-state.json
# PostgreSQL/TimescaleDB（CYP_PERSISTENCE=postgres 时使用；docker compose 可直接启动）
CYP_DB_URL=postgresql://cyp:cyp@localhost:5433/cyp
CYP_LOG_LEVEL=INFO
