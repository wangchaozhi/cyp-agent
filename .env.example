# ============================================================================
# cyp-agent 配置参考（单一来源）。复制为 .env 即可。
# 默认值 = 零密钥、模拟盘、mock LLM —— 直接可端到端跑通。
# ============================================================================

# ---- 运行模式 ----------------------------------------------------------------
CYP_MODE=paper                 # paper（默认，模拟盘）| live（实盘，需前置校验）
CYP_APPROVAL=cli               # cli | dashboard | auto（auto 仅 M6，受策略护栏约束）
CYP_KILL=0                     # 1 = Kill Switch 开启，拒绝一切新提案/下单
CYP_ALLOW_PERP=0               # 1 = 允许策略官提出永续合约（默认仅现货，更保守）

# ---- LLM（缺失则所有 Agent 降级为规则模板）----------------------------------
ANTHROPIC_API_KEY=             # sk-ant-...；留空 = mock LLM 降级
CYP_LLM_MODEL=claude-opus-4-8  # 决策/评审模型
CYP_LLM_MODEL_FAST=claude-haiku-4-5-20251001   # 指标解读等轻量调用

# ---- LLM 成本护栏（四重硬上限，任一触发即优雅终止）--------------------------
CYP_MAX_ITERATIONS=20
CYP_MAX_TOKENS=200000
CYP_MAX_COST_USD=2.0
CYP_MAX_WALL_SECONDS=300

# ---- CEX（只读行情无需 Key；实盘下单需授「读+交易」权限，永久禁用提现）-------
CYP_CEX_ID=binance             # ccxt 交易所 id
BINANCE_API_KEY=               # 实盘才需要
BINANCE_API_SECRET=
# ⚠️ 交易所侧务必：开启 IP 白名单 + 禁用提现权限

# ---- 链上（M3；留空则 OnchainVenue 不可用，不影响 CEX）----------------------
CYP_EVM_RPC_URL=               # 主网/L2 RPC；建议用支持私有内存池的防夹 RPC
CYP_SIGNER=keystore            # keystore | kms | hardware（私钥永不落盘明文/入日志/进 LLM）
CYP_KEYSTORE_PATH=             # 加密 keystore 路径（不入库、不进日志）

# ---- 数据源（可选；缺失则对应分析师降级）------------------------------------
CYP_SENTIMENT_API=             # 情绪/新闻源；留空 = 情绪分析师 degraded
CYP_ONCHAIN_DATA_API=          # 聪明钱/流动性数据商；留空 = 链上分析师跳过

# ---- 风控硬护栏（实盘应显式设置且比默认更保守，详见 docs/RISK.md）-----------
CYP_MAX_RISK_PER_TRADE=0.01    # 单笔风险 ≤ 账户 1%
CYP_MAX_POSITION_PCT=0.20      # 单仓名义上限 20%
CYP_MAX_GROSS_EXPOSURE=1.00    # 总敞口上限
CYP_MAX_SYMBOL_CONCENTRATION=0.30
CYP_MAX_LEVERAGE=3             # 永续杠杆上限（保守起步）
CYP_MIN_LIQ_BUFFER=0.30        # 入场到爆仓价最小缓冲
CYP_FORCE_ISOLATED=true        # 合约强制逐仓（风险隔离）
CYP_MIN_MARGIN_RATIO=0.05      # 账户维持保证金率下限，低于则冻结新开合约仓
CYP_MAX_SLIPPAGE_BPS=30
CYP_MAX_PRICE_IMPACT=0.01      # 链上 swap 价格冲击上限
CYP_MAX_GAS_GWEI=              # 链上 gas 上限
CYP_DAILY_DRAWDOWN_LIMIT=0.03  # 日回撤熔断
CYP_WEEKLY_DRAWDOWN_LIMIT=0.08
CYP_MAX_DRAWDOWN_LIMIT=0.15
CYP_MAX_CONSECUTIVE_LOSSES=4
CYP_MAX_ORDERS_PER_HOUR=10
CYP_APPROVAL_TIMEOUT_SECONDS=1800   # 审批超时=拒绝（fail-safe）

# ---- 持久化 & 可观测 --------------------------------------------------------
CYP_DB_PATH=./data/cyp.db      # aiosqlite（WAL，崩溃可恢复）
CYP_LOG_LEVEL=INFO             # JSON 结构化日志，自动脱敏 key/私钥/token
