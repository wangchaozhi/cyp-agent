# ============================================================================
# cyp-agent 配置参考。复制为 .env 后按需取消注释并填写。
# 默认值 = 零密钥、模拟盘、mock LLM，可端到端跑通。
# ============================================================================

# ---- 运行模式 ----------------------------------------------------------------
CYP_MODE=paper
CYP_APPROVAL=cli
# approval=auto 的策略白名单（M6）：三条全满足才自动批准，否则转人工
# CYP_AUTO_SYMBOLS=BTC/USDT,ETH/USDT
# CYP_AUTO_MAX_RISK_SCORE=0.5
# CYP_AUTO_MAX_QUOTE=200
CYP_KILL=0
CYP_ALLOW_PERP=0
CYP_EXECUTION_VENUE=paper
CYP_DATA_SOURCE=synthetic

# ---- LLM（缺失则所有 Agent 降级为规则模板）----------------------------------
# CYP_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
CYP_LLM_MODEL=claude-opus-4-8
CYP_LLM_MODEL_FAST=claude-haiku-4-5-20251001

# DeepSeek（OpenAI-compatible；启用时取消注释以下配置）
# CYP_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# CYP_LLM_BASE_URL=https://api.deepseek.com
# CYP_LLM_MODEL=deepseek-chat
# CYP_LLM_MODEL_FAST=deepseek-chat

# ---- LLM 成本护栏（四重硬上限，任一触发即优雅终止）--------------------------
CYP_MAX_ITERATIONS=20
CYP_MAX_TOKENS=200000
CYP_MAX_COST_USD=2.0
CYP_MAX_WALL_SECONDS=300

# ---- CEX（只读行情无需 Key；实盘下单需授「读+交易」权限，永久禁用提现）-------
CYP_CEX_ID=binance
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
CYP_LIVE_ACK=0
# 交易所侧务必：开启 IP 白名单 + 禁用提现权限。

# ---- OKX 模拟交易（Demo Trading；需在 OKX 后台创建“模拟盘”API 凭据）----------
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSWORD=
CYP_OKX_DEMO=true

# ---- 告警（可选）------------------------------------------------------------
# CYP_ALERT_WEBHOOK=

# ---- 链上（M3；留空则 OnchainVenue 不可用，不影响 CEX）----------------------
# CYP_EVM_RPC_URL=
CYP_SIGNER=keystore
# CYP_KEYSTORE_PATH=

# ---- 数据源（可选；缺失则对应分析师降级）------------------------------------
# CYP_SENTIMENT_API=
# CYP_ONCHAIN_DATA_API=

# ---- 风控硬护栏（实盘应显式设置且比默认更保守，详见 docs/RISK.md）-----------
CYP_MAX_RISK_PER_TRADE=0.01
CYP_MAX_POSITION_PCT=0.20
CYP_MAX_GROSS_EXPOSURE=1.00
CYP_MAX_SYMBOL_CONCENTRATION=0.30
CYP_MAX_CORRELATED_EXPOSURE=0.50
CYP_MAX_CVAR_PCT=0.03
CYP_MAX_LEVERAGE=3
CYP_MIN_LIQ_BUFFER=0.30
CYP_FORCE_ISOLATED=true
CYP_MIN_MARGIN_RATIO=0.05
CYP_MAX_SLIPPAGE_BPS=30
# 链上专项（§2.3）
CYP_MAX_PRICE_IMPACT=0.01
# CYP_MAX_GAS_GWEI=
CYP_MAX_GAS_QUOTE=20
CYP_MIN_POOL_TVL=1000000
# 合约/路由白名单（逗号分隔小写地址；空 = 链上全拒）
# CYP_CONTRACT_WHITELIST=
CYP_REQUIRE_PRIVATE_MEMPOOL=true
CYP_DAILY_DRAWDOWN_LIMIT=0.03
CYP_WEEKLY_DRAWDOWN_LIMIT=0.08
CYP_MAX_DRAWDOWN_LIMIT=0.15
CYP_MAX_CONSECUTIVE_LOSSES=4
CYP_MAX_ORDERS_PER_HOUR=10
CYP_APPROVAL_TIMEOUT_SECONDS=1800

# ---- 运行时（扫描 + 监控双循环）----------------------------------------------
# true：FastAPI 启动时同时启动 RuntimeEngine（扫描+监控）
CYP_RUNTIME_AUTOSTART=false
CYP_SCAN_INTERVAL=300
CYP_MONITOR_INTERVAL=15
CYP_WATCHLIST=BTC/USDT
CYP_MAX_CONCURRENCY=2

# ---- 持久化 & 可观测 --------------------------------------------------------
CYP_DB_PATH=./data/cyp.db
CYP_LOG_LEVEL=INFO
